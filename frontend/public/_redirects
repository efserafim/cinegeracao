/uploads/*  https://cinegeracao.onrender.com/uploads/:splat  200!

# PWA: não deixar o SPA engolir SW e manifesto
/admin/sw.js  /admin/sw.js  200!
/admin/manifest.webmanifest  /admin/manifest.webmanifest  200!

# Admin: HTML próprio (OG WhatsApp diferente do site público)
/admin  /admin.html  200!
/admin/  /admin.html  200!
