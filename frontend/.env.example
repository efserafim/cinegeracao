# Em produção no Netlify: deixe /api (há proxy no netlify.toml → Render).
# Local: Vite faz proxy para localhost:3001.
VITE_API_URL=/api

# Se preferir chamar o Render direto (sem proxy), use:
# VITE_API_URL=https://cinegeracao.onrender.com/api

# Supabase Auth + API
VITE_SUPABASE_URL=https://SEU_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...
