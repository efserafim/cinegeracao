# Servidor
NODE_ENV=development
PORT=3001
# Domínios permitidos no CORS (vírgula). Links de e-mail usam geucaristica se estiver na lista.
FRONTEND_URL=https://geucaristica.com.br,https://www.geucaristica.com.br,https://cinegeracao.netlify.app,http://localhost:5173
# Opcional: força o domínio dos links do e-mail/WhatsApp
PUBLIC_SITE_URL=https://geucaristica.com.br

# Banco de dados – local ou Supabase
# Local:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cinegeracao?schema=public"
# Supabase (Settings → Database → Connection string → URI):
DATABASE_URL="postgresql://postgres:SUA_SENHA@db.SEU_PROJECT_REF.supabase.co:5432/postgres?schema=public"
SUPABASE_URL="https://SEU_PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="sb_publishable_..."
# Recomendado no Render: service role para upload de banners no Storage
# SUPABASE_SERVICE_ROLE_KEY="eyJ..."
# SUPABASE_STORAGE_BUCKET=banners


# JWT
JWT_SECRET=altere_esta_chave_para_um_valor_seguro_e_longo
JWT_EXPIRES_IN=8h

# Upload
MAX_FILE_SIZE_MB=15
UPLOAD_DIR=uploads

# OCR (tesseract | google_vision)
OCR_PROVIDER=tesseract
# GOOGLE_VISION_API_KEY=

# E-mail — Brevo (recomendado) https://app.brevo.com
# 1) Senders, Domains & IPs → Domains → Add domain: geucaristica.com.br
# 2) Autenticar domínio: copie TXT (Brevo code + DKIM + DMARC) → Registro.br → Salvar
# 3) Verificar no Brevo
# 4) Senders: criar remetente noreply@geucaristica.com.br
# 5) SMTP & API → API Keys → Create a new API key
# 6) No Render:
BREVO_API_KEY=
SMTP_FROM="CineGeração <noreply@geucaristica.com.br>"

# Remova as outras keys para não misturar:
# RESEND_API_KEY=
# SENDGRID_API_KEY=

# SMTP clássico (pode falhar no Render)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=seu-email@gmail.com
# SMTP_PASS=sua-senha-de-app

# Admin inicial (seed) – use o MESMO e-mail em Supabase → Authentication → Users
ADMIN_EMAIL=admin@cinegeracao.local
ADMIN_PASSWORD=Admin@123
ADMIN_NOME=Administrador

# Admins mestres (Lavínia + Eduardo) — perfil ADMIN completo
# Lavínia: laviniadossantos22@gmail.com (fixo no código)
# Eduardo (altere se o login no Supabase for outro e-mail):
EDUARDO_ADMIN_EMAIL=setorjuventude.bacaxa@gmail.com
# MASTER_ADMIN_PASSWORD=Admin@Master1
